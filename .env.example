# Copy this file to .env and fill in your values

# OpenAI API key — used for Whisper transcription when YouTube transcript is unavailable
OPENAI_API_KEY=sk-...

# Anthropic API key — used for Claude summarization
ANTHROPIC_API_KEY=sk-ant-...

# Notion integration secret (from https://www.notion.so/my-integrations)
NOTION_TOKEN=secret_...

# Notion parent page ID — the page where new video pages will be created
# Find it in the page URL: notion.so/{workspace}/{PAGE_ID}?v=...
NOTION_PAGE_ID=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

#!/bin/bash
# ══════════════════════════════════════════════════════════════
# Pre-commit hook: Block commits containing secrets
# ══════════════════════════════════════════════════════════════
# Scans staged files for patterns that look like real API keys,
# tokens, or passwords. Blocks the commit if any are found.

RED='\033[0;31m'
YELLOW='\033[1;33m'
NC='\033[0m' # No Color

# Patterns that indicate real secrets (not placeholders like "sk-proj-...")
SECRET_PATTERNS=(
    'sk-proj-[A-Za-z0-9_-]{20,}'        # OpenAI API key
    'sk-ant-[A-Za-z0-9_-]{20,}'         # Anthropic API key
    'ntn_[A-Za-z0-9]{20,}'              # Notion integration token
    'secret_[A-Za-z0-9]{20,}'           # Notion old-style token
    '[0-9]{8,}:AA[A-Za-z0-9_-]{30,}'    # Telegram bot token
    'ghp_[A-Za-z0-9]{36}'               # GitHub personal access token
    'gho_[A-Za-z0-9]{36}'               # GitHub OAuth token
    'AKIA[0-9A-Z]{16}'                  # AWS access key
    'xoxb-[0-9]+-[A-Za-z0-9]+'         # Slack bot token
)

# Only scan staged files (what's about to be committed)
STAGED_FILES=$(git diff --cached --name-only --diff-filter=ACM)

if [ -z "$STAGED_FILES" ]; then
    exit 0
fi

FOUND_SECRETS=0

for pattern in "${SECRET_PATTERNS[@]}"; do
    # Search staged content (not working directory)
    MATCHES=$(git diff --cached -U0 | grep -E "^\+" | grep -oE "$pattern" 2>/dev/null)
    if [ -n "$MATCHES" ]; then
        if [ $FOUND_SECRETS -eq 0 ]; then
            echo ""
            echo -e "${RED}🚨 SECRETS DETECTED — COMMIT BLOCKED${NC}"
            echo "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"
        fi
        FOUND_SECRETS=1
        echo -e "${YELLOW}Pattern:${NC} $pattern"
        echo "$MATCHES" | while read -r match; do
            # Show first/last 6 chars only
            PREVIEW="${match:0:6}...${match: -6}"
            echo -e "  Found: ${RED}$PREVIEW${NC}"
        done
        echo ""
    fi
done

# Also check if .env file is being committed
if echo "$STAGED_FILES" | grep -qE '^\.env$'; then
    if [ $FOUND_SECRETS -eq 0 ]; then
        echo ""
        echo -e "${RED}🚨 SECRETS DETECTED — COMMIT BLOCKED${NC}"
        echo "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"
    fi
    FOUND_SECRETS=1
    echo -e "${YELLOW}.env file is staged for commit!${NC}"
    echo "  Run: git reset HEAD .env"
    echo ""
fi

if [ $FOUND_SECRETS -ne 0 ]; then
    echo "To fix:"
    echo "  1. Remove secrets from the file"
    echo "  2. Use .env for secrets, .env.example for placeholders"
    echo "  3. git reset HEAD <file> to unstage"
    echo ""
    echo "To bypass (DANGEROUS): git commit --no-verify"
    echo ""
    exit 1
fi

exit 0
